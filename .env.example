# ============================================
# Library Management System - Environment Variables
# ============================================
#
# Docker host ports (published). Defaults use the 330x block — see
# ../observability-platform/docs/ARCHITECTURE.md
LIBRARY_HOST_FRONTEND_PORT=3300
LIBRARY_HOST_BACKEND_PORT=3301

# ============================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values (never commit .env to git!)
# 3. Restart Docker Compose: docker compose restart
# ============================================

# AUTH_STORAGE was removed. Legacy authentication and storage use SQLite only.

# ============================================
# JWT Secret (for token signing)
# ============================================
# Generate a secure random string for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
JWT_SECRET=development-secret-key-change-in-production

# ============================================
# SQLite Database Path (for SQLite mode)
# ============================================
# Default path (inside Docker container)
# Outside Docker, use relative path: ./data/library.sqlite
SQLITE_PATH=/app/data/library.sqlite

# ============================================
# Proxy Configuration (Corporate Networks Only)
# ============================================
# Uncomment and set if you're behind a corporate proxy:
#
# HTTP_PROXY=http://proxy.company.com:8080
# HTTPS_PROXY=http://proxy.company.com:8080
# NO_PROXY=localhost,127.0.0.1,*.local

# ============================================
# CORS Origin (Frontend URL)
# ============================================
# Default: http://localhost:3300 (matches docker-compose.yml)
# Change if your frontend runs on a different port
# CORS_ORIGIN=http://localhost:3300

# ============================================
# Keycloak — workspace identity-platform (Phase 1.5+)
# ============================================
# IAM is shared across all My Projects apps. Start: cd ../identity-platform && docker compose up -d
# Docs: ../identity-platform/docs/ARCHITECTURE.md
#
KEYCLOAK_URL=http://localhost:3510
KEYCLOAK_REALM=library
KEYCLOAK_CLIENT_ID=library-frontend
# Browser-facing issuer base (JWT iss). Required when backend uses KEYCLOAK_INTERNAL_URL.
KEYCLOAK_PUBLIC_URL=http://localhost:3510
# Backend Docker uses KEYCLOAK_INTERNAL_URL in compose (host.docker.internal:3510) for JWKS only
# NEXT_PUBLIC_IAM_PROVIDER=keycloak
# NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:3510
# NEXT_PUBLIC_KEYCLOAK_REALM=library
# NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=library-frontend
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
# KEYCLOAK_BACKEND_CLIENT_ID=library-backend
# KEYCLOAK_BACKEND_CLIENT_SECRET=library-backend-dev-secret-change-in-production

# ============================================
# Firebase Firestore — workspace data platform (Phase 2+)
# ============================================
# Shared dev project + per-app collection prefix. See ../identity-platform/docs/DATA-PLATFORM.md
#
# FIREBASE_PROJECT_ID=personal-apps-dev
# APP_FIRESTORE_PREFIX=library
# GOOGLE_APPLICATION_CREDENTIALS=../identity-platform/secrets/firebase-dev.json

# IAM_PROVIDER=keycloak         # legacy | keycloak
# DATA_STORAGE=firebase         # legacy | firebase
# NEXT_PUBLIC_IAM_PROVIDER=keycloak  # must match IAM_PROVIDER for frontend OIDC
