# Copy to `env.build` (gitignored) and edit for your machine / environment.
# Then run:  ../scripts/run-mobile-local.sh   (recommended)
# Or:        ./build-mobile.sh
#
# Never use 127.0.0.1 / localhost for device testing — that is the phone itself.

# local  = same Wi‑Fi / hotspot → host LAN IP + Docker host ports
# public = hosted HTTPS endpoints (staging / production)
LIBRARY_CONNECTIVITY=local

# --- Local (LAN) ---
# Find IP: ../scripts/lan-ip.sh   or  ipconfig getifaddr en0
LIBRARY_LAN_IP=192.168.0.1
LIBRARY_WEB_PORT=3300
LIBRARY_API_PORT=3301
LIBRARY_KEYCLOAK_PORT=3510

# Optional explicit overrides (win over LAN_IP + ports when set):
# LIBRARY_WEB_URL=http://192.168.0.1:3300
# LIBRARY_API_URL=http://192.168.0.1:3301/api
# LIBRARY_KEYCLOAK_URL=http://192.168.0.1:3510

# remote = Capacitor opens WEB_URL directly (Docker frontend NEXT_PUBLIC_* must match)
# bridge = local shell writes API/KC into localStorage then redirects (use when overriding API/KC independently)
# LIBRARY_SHELL_MODE=remote

# --- Public (later) ---
# LIBRARY_CONNECTIVITY=public
# LIBRARY_WEB_URL=https://library.example.com
# LIBRARY_API_URL=https://api.library.example.com/api
# LIBRARY_KEYCLOAK_URL=https://auth.example.com
# LIBRARY_KEYCLOAK_REALM=library
# LIBRARY_KEYCLOAK_CLIENT_ID=library-frontend

LIBRARY_KEYCLOAK_REALM=library
LIBRARY_KEYCLOAK_CLIENT_ID=library-frontend

# Capacitor app metadata
LIBRARY_APP_ID=com.librarymanagement.app
LIBRARY_APP_NAME='Library Management'
LIBRARY_SHELL_MODE=remote
